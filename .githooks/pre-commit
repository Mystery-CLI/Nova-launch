#!/bin/bash
# Pre-commit hook for code quality enforcement
# Runs fast, targeted checks on staged files only.
# Install: git config core.hooksPath .githooks

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

FAILED=0

fail() { echo -e "${RED}❌ $1${NC}"; FAILED=1; }
pass() { echo -e "${GREEN}✓ $1${NC}"; }
info() { echo -e "${YELLOW}▶ $1${NC}"; }

echo "🔍 Running pre-commit checks..."

# ── Conventional commit message validation ────────────────────────────────────
COMMIT_MSG_FILE=".git/COMMIT_EDITMSG"
if [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")
  CONVENTIONAL_PATTERN='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert|infra)(\([a-z0-9/_-]+\))?(!)?: .+'
  if ! echo "$COMMIT_MSG" | grep -qE "$CONVENTIONAL_PATTERN"; then
    fail "Commit message does not follow Conventional Commits format."
    echo "  Expected: <type>(<scope>): <description>"
    echo "  Types: feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert|infra"
    echo "  Got: $COMMIT_MSG"
    FAILED=1
  else
    pass "Commit message format OK"
  fi
fi

# ── Secret detection (basic patterns) ────────────────────────────────────────
info "Checking for secrets in staged files..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SECRET_PATTERNS=(
  'PRIVATE_KEY\s*=\s*["\x27][A-Za-z0-9+/]{20,}'
  'SECRET\s*=\s*["\x27][A-Za-z0-9+/]{20,}'
  'API_KEY\s*=\s*["\x27][A-Za-z0-9+/]{20,}'
  'PASSWORD\s*=\s*["\x27][^"\x27]{8,}'
  'sk_live_[A-Za-z0-9]+'
  'ghp_[A-Za-z0-9]{36}'
  'AAAA[A-Za-z0-9+/]{40,}'
)
SECRET_FOUND=0
for file in $STAGED_FILES; do
  # Skip binary files and known safe files
  [[ "$file" == *.png || "$file" == *.jpg || "$file" == *.wasm || "$file" == *.lock ]] && continue
  [[ "$file" == *".env.example" || "$file" == *".env.test" ]] && continue
  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git diff --cached -- "$file" | grep -qE "$pattern" 2>/dev/null; then
      fail "Possible secret detected in $file (pattern: $pattern)"
      SECRET_FOUND=1
    fi
  done
done
[ $SECRET_FOUND -eq 0 ] && pass "No secrets detected"

# ── Rust checks (staged .rs files only) ──────────────────────────────────────
if echo "$STAGED_FILES" | grep -q "\.rs$"; then
  info "Checking Rust formatting..."
  if (cd contracts/token-factory && cargo fmt --check 2>/dev/null); then
    pass "Rust formatting OK"
  else
    fail "Rust formatting failed. Run: cd contracts/token-factory && cargo fmt"
  fi
fi

# ── Frontend checks (staged frontend files only) ──────────────────────────────
FRONTEND_CHANGED=$(echo "$STAGED_FILES" | grep "^frontend/.*\.\(ts\|tsx\|js\|jsx\)$" || true)
if [ -n "$FRONTEND_CHANGED" ]; then
  info "Checking frontend linting..."
  if (cd frontend && npm run lint --silent 2>/dev/null); then
    pass "Frontend linting OK"
  else
    fail "Frontend linting failed. Run: cd frontend && npm run lint -- --fix"
  fi

  info "Checking frontend types..."
  if (cd frontend && npm run type-check --silent 2>/dev/null); then
    pass "Frontend type-check OK"
  else
    fail "Frontend type-check failed. Run: cd frontend && npm run type-check"
  fi
fi

# ── Backend checks (staged backend files only) ────────────────────────────────
BACKEND_CHANGED=$(echo "$STAGED_FILES" | grep "^backend/.*\.\(ts\|tsx\|js\|jsx\|json\)$" || true)
if [ -n "$BACKEND_CHANGED" ]; then
  info "Checking backend formatting..."
  if (cd backend && npm run format:check --silent 2>/dev/null); then
    pass "Backend formatting OK"
  else
    fail "Backend formatting failed. Run: cd backend && npm run format"
  fi

  info "Checking backend types..."
  if (cd backend && npm run type-check --silent 2>/dev/null); then
    pass "Backend type-check OK"
  else
    fail "Backend type-check failed. Run: cd backend && npm run type-check"
  fi
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo ""
if [ $FAILED -ne 0 ]; then
  echo -e "${RED}✗ Pre-commit checks failed. Fix the issues above before committing.${NC}"
  echo "  To skip (not recommended): git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
